{
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev --open",
		"build": "xo && astro build",
		"preview": "astro preview",
		"test": "xo && astro build"
	},
	"overrides": {
		"esbuild": "^0.28.1"
	},
	"devDependencies": {
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@astropub/md": "^1.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@typescript-eslint/parser": "^8.61.1",
		"astro": "^6.4.7",
		"astro-iconify": "^1.3.1",
		"eslint-plugin-astro": "^1.7.0",
		"ky": "^1.14.3",
		"limax": "^4.2.3",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-custom-header-id": "^1.0.0",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"postcss": "^8.5.10",
		"cssnano": "^7.1.9",
		"autoprefixer": "^10.5.0",
		"xo": "^0.59.3"
	},
	"xo": {
		"envs": [
			"es2021",
			"node",
			"browser"
		],
		"globals": [
			"Astro",
			"Fragment"
		],
		"extensions": [
			"astro"
		],
		"ignores": [
			"source/content.config.ts",
			"public/count.min.js"
		],
		"overrides": [
			{
				"files": [
					"**/*.astro"
				],
				"parser": "astro-eslint-parser",
				"parserOptions": {
					"parser": "@typescript-eslint/parser"
				},
				"extraFileExtensions": [
					".astro"
				]
			}
		],
		"rules": {
			"unicorn/filename-case": "off",
			"unicorn/text-encoding-identifier-case": "off",
			"n/file-extension-in-import": "off",
			"operator-linebreak": "off",
			"jsx-quotes": [
				"error",
				"prefer-double"
			],
			"unicorn/prevent-abbreviations": "off"
		}
	}
}